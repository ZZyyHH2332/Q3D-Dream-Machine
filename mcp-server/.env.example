# Q3D 形象造梦机 MCP Server 配置
# 复制此文件为 .env 并填写你的 API 密钥

# AI 图像生成 API 密钥（支持 OpenAI 兼容接口）
Q3D_API_KEY=

# API 基地址（默认 OpenAI，可切换至国内百炼/通义万相等）
Q3D_API_BASE=https://api.openai.com/v1

# 输出目录（可选，默认项目根目录 assets/generated）
# Q3D_OUTPUT_DIR=../assets/generated

# 上传目录（可选，默认项目根目录 assets/uploads）
# Q3D_UPLOADS_DIR=../assets/uploads

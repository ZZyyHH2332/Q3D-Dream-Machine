# Q3D 形象造梦机 MCP Server 配置
# 复制此文件为 .env 并填写你的配置

# ===== 主 AI Provider 配置（TRAE 原生优先）=====
# 可选: trae | external | auto（默认 auto，自动探测）
# - trae: 使用 TRAE IDE 内置多模态模型 + GenerateImage 工具
#   （TRAE 模式下，Vision 分析和图像生成由 TRAE Agent 直接调度，
#    MCP Server 负责文件管理、会话管理、3D 生成等业务逻辑）
# - external: 使用外部 API（OpenAI 兼容接口，如 OpenAI / 豆包 / 通义万相）
# - auto: 自动探测（优先 trae，不可用降级 external，最后 mock）
Q3D_AI_PROVIDER=auto

# TRAE Native 模式配置
# 是否启用 TRAE 内置 Vision 分析（默认 true）
# Q3D_TRAE_VISION_ENABLED=true
# TRAE 图像生成模型（默认 auto，由 TRAE 自动选择）
# Q3D_TRAE_IMAGE_MODEL=auto

# ===== 外部 API 配置（向后兼容，external 模式使用）=====
# AI 图像生成 API 密钥（支持 OpenAI 兼容接口）
Q3D_API_KEY=

# API 基地址（默认 OpenAI，可切换至国内百炼/通义万相等）
Q3D_API_BASE=https://api.openai.com/v1

# ===== 测试模式 =====
# 设为 mock 时跳过所有真实 API 调用，使用本地模拟数据
# Q3D_TEST_MODE=mock

# ===== 输出目录配置 =====
# 输出生成目录（可选，默认项目根目录 assets/generated）
# Q3D_OUTPUT_DIR=../assets/generated

# 上传目录（可选，默认项目根目录 assets/uploads）
# Q3D_UPLOADS_DIR=../assets/uploads

# 作品索引文件路径（可选，默认项目根目录 works-index.json）
# Q3D_WORKS_INDEX=../works-index.json

# ===== 3D 模型生成 Provider 配置 =====
# 可选: hunyuan | tripo | 302ai | auto（默认 auto，自动探测可用服务）
Q3D_3D_PROVIDER=auto

# Hunyuan3D 本地 API Server 地址（默认 localhost:8080）
# Q3D_HUNYUAN_API_URL=http://localhost:8080

# 302.AI API Key（无 GPU 用户的云方案，每日签到有免费积分）
# Q3D_302AI_API_KEY=

# Tripo3D API Key（保底降级，每月 200 free credits）
# Q3D_TRIPO_API_KEY=
